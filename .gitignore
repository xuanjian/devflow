.DS_Store
**/.DS_Store

# Runtime task instances may contain Jira details, screenshots, temporary notes,
# or environment-specific evidence. Track the protocol README, not ticket data.
runtime/tasks/*
!runtime/tasks/README.md
!runtime/tasks/*.json

# Skill runtime outputs. Keep source scripts/templates, ignore local backups/logs.
bundles/skills/dhb-local-env/runtime/backups/*
bundles/skills/dhb-local-env/runtime/logs/*
bundles/skills/dhb-local-env/runtime/pids/*

# Local editor and tool noise.
node_modules/
.superpowers/
.idea/
.vscode/
*.swp
*.tmp
