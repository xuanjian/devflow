.DS_Store
**/.DS_Store

# Runtime task instances may contain Jira details, screenshots, temporary notes,
# or environment-specific evidence. Track the protocol README, not ticket data.
runtime/tasks/*
!runtime/tasks/README.md
!runtime/tasks/.gitkeep

# Local editor, generated skill links, and tool noise.
.codex/skills/
.claude/skills/
node_modules/
.playwright-mcp/
.superpowers/
.idea/
.vscode/
*.swp
*.tmp
