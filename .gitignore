.DS_Store
**/.DS_Store

# Runtime task instances may contain Jira details, screenshots, temporary notes,
# local project links, or environment-specific evidence. Track only the empty
# framework placeholder in master.
runtime/tasks/*
!runtime/tasks/.gitkeep
runtime/backups/
runtime/stale-migration-files/
runtime/*.json
!runtime/current.json
runtime/current.local.json
data/*.db
data/*.db-*

# Local project, scene, rule, skill, and registry data. The public/master branch
# should remain a fresh DevFlow framework, not one machine's inventory.
config/projects/*
!config/projects/
!config/projects/index.json
!config/projects/devflow.json

config/scenes/*
!config/scenes/
!config/scenes/index.json
!config/scenes/devflow-config.json

bundles/rules/
bundles/skills/*
!bundles/skills/
!bundles/skills/devflow/
!bundles/skills/devflow/**
!bundles/skills/devflow-init/
!bundles/skills/devflow-init/**

docs/person/
docs/repos/
docs/scenes/
docs/reference/
docs/superpowers/
docs/prototypes/
docs/templates/

registry/

# Local editor, generated skill links, and tool noise.
.agents/skills/
.codex/skills/
.claude/skills/
node_modules/
apps/panel/node_modules/
apps/panel/.vite/
.playwright-mcp/
.superpowers/
.idea/
.vscode/
*.swp
*.tmp
